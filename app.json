{
  "expo": {
    "name": "Ride Radar",
    "slug": "ride-radar",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "rideradar",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0D0D0D",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rideradar.app",
      "config": {
        "googleMapsApiKey": "YOUR_IOS_GOOGLE_MAPS_API_KEY"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "package": "com.rideradar.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Ride Radar needs your location to show nearby riders, crew rides, and events on the radar map.",
          "locationWhenInUsePermission": "Ride Radar needs your location to show nearby riders, crew rides, and events on the radar map."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
